# LLM Gateways — an OpenAI-compatible proxy layer in front of your host's
# Ollama models (and, optionally, any hosted provider you add an API key
# for). Independent of NanoClaw and the chat-frontends environment entirely
# — any of them can point at whichever gateway you enable here instead of
# talking to Ollama directly, to get a single stable endpoint, request
# logging, or (if you opt into Postgres) per-caller virtual keys.

# Space-separated container name this environment manages — used by
# deploy.sh's CLEAN policy to identify which containers to tear down. Only
# the flagship (LiteLLM) service uses this literally; every other service
# below is prefixed with it instead (litellm-postgres, etc.) — see
# docker-compose.yml's own comment on why.
# Format: A single Docker container name.
CONTAINER_NAME=litellm

# Which gateways actually run — a comma-separated list of Docker Compose
# profile names, matching the "profiles:" list on each service in
# docker-compose.yml. This is a REAL Docker Compose mechanism
# (COMPOSE_PROFILES is read straight out of .env automatically, nothing
# this repo invented) — add or remove names to turn a service on or off,
# then redeploy (FAST is enough, no rebuild needed). "all" runs everything,
# including LiteLLM's opt-in Postgres (see LITELLM_DATABASE_URL below for
# why that one's excluded here by default).
# Format: Comma-separated, from: litellm, litellm-db, portkey (or "all").
COMPOSE_PROFILES=litellm

# Host port for LiteLLM's own OpenAI-compatible endpoint.
# Format: A valid local TCP port. Access via http://<host-ip>:<port>
LITELLM_PORT=4000

# Protects LiteLLM's endpoint itself — callers must send this as a Bearer
# token. Generate one yourself, don't leave the placeholder.
# Format: A random string, e.g. from `openssl rand -base64 32`, or
# LiteLLM's own convention of prefixing it "sk-".
LITELLM_MASTER_KEY=CHANGE_ME_RUN_OPENSSL_RAND_BASE64_32

# Where LiteLLM (and Portkey, if you route through it) looks for Ollama.
# Defaults to host.docker.internal, Docker's own hostname for reaching the
# host machine from inside a container — correct if you followed the
# nanoclaw-mnemon environment's own Ollama setup (host-native, not
# containerized — see that environment's README for why). Change this only
# if Ollama runs somewhere else (a different machine, a container of its
# own, a non-default port).
#
# Known caveat on OrbStack specifically (confirmed directly while building
# the chat-frontends environment): host.docker.internal there resolves to
# OrbStack's own internal pseudo-address, not this bridge network's actual
# gateway — this breaks reaching another *container's* published port
# through it, but the HOST's own Ollama daemon (a real process, not a
# container) is still reachable fine, since that's exactly the case this
# mechanism is designed for. If it still doesn't work, find your bridge's
# real gateway IP and use that instead:
#   docker network inspect bridge --format '{{json .IPAM.Config}}'
# Format: A URL these containers can reach.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Optional hosted-provider keys — only used if you've uncommented the
# matching model_list entry in litellm-config.yaml. Leave blank to run
# Ollama-only; nothing else in this environment requires these.
# Format: The provider's own API key string.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Optional: LiteLLM's Postgres (Virtual Keys / spend tracking / Admin UI login) ---
# Both of these are only read if you've added "litellm-db" to
# COMPOSE_PROFILES above — leaving that profile off means neither is used
# and this section can stay untouched.

# Full connection string LiteLLM itself uses to reach litellm-postgres
# below. The hostname/user/db name here must match litellm-postgres's own
# POSTGRES_USER/POSTGRES_DB (litellm/litellm, not user-configurable) —
# only the password varies, which must match LITELLM_DB_PASSWORD exactly.
# Format: postgresql://litellm:<LITELLM_DB_PASSWORD>@litellm-postgres:5432/litellm
LITELLM_DATABASE_URL=

# Password for LiteLLM's own dedicated Postgres database (a separate
# container this environment manages, not your host's own Postgres if you
# happen to have one). Generate one yourself — don't leave the placeholder.
# Format: A password string, e.g. from `openssl rand -base64 24`.
LITELLM_DB_PASSWORD=CHANGE_ME_TO_A_SECURE_PASSWORD

# Host port for Portkey Gateway's own interface. Only relevant if "portkey"
# is in COMPOSE_PROFILES above.
# Format: A valid local TCP port. Access via http://<host-ip>:<port>
PORTKEY_PORT=8787
