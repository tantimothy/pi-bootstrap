# Standalone Claude CLI, reachable directly over its own SSH server — no
# NanoClaw, no channel bots, no Docker-outside-of-Docker. Point it at a git
# repo on the host and SSH in from any machine that holds the matching
# private key; you land straight into a persistent `claude` session that
# survives disconnects (see the README's "How Login Works").

# The container's name.
# Format: A single Docker container name.
CONTAINER_NAME=claude-cli

# Host port that reaches this container's own sshd (mapped to its internal
# port 22). Kept off the standard 22 so it never collides with the host's
# own sshd if you're also SSH'ing into the host machine itself.
# Format: A valid local TCP port.
SSH_PORT=2222

# Absolute path to the git repo (or any directory) you want `claude` to
# operate on. Bind-mounted to ~/workspace inside the container — that's
# where the auto-attached tmux session's `claude` starts.
# Format: An absolute path, or a leading ~ (expanded to your home directory
# when this is written to .env via deploy.sh's TUI — plain "~"/"~/..." only).
CLAUDE_WORKSPACE_PATH=~/claude-cli-workspace

# Path to a file listing the public keys allowed to SSH into this
# container — one per line, standard authorized_keys format. Defaults to
# the same file your own host's sshd already trusts, so anyone who can
# already SSH into this machine can also SSH straight into this container
# (no separate key management to set up). Point it at a dedicated file
# instead if you want a narrower set of keys than your host grants.
# Format: An absolute path, or a leading ~, to an existing authorized_keys
# file. Editing this file on the host takes effect on the container's next
# restart (FAST) — no rebuild needed.
SSH_AUTHORIZED_KEYS_PATH=~/.ssh/authorized_keys

# UID/GID the "claude" user inside the container is renumbered to at every
# start, so files it creates in CLAUDE_WORKSPACE_PATH are owned by you on
# the host, not by an arbitrary container-only UID. Set to your own `id -u`
# / `id -g` if they're not the common default 1000/1000 (check with `id`).
# Format: Integers.
PUID=1000
PGID=1000
