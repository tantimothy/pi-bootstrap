# Overrides the primary ntopng container's name. The ntopng-redis sidecar
# keeps its own bare name by default, but gets prefixed with this value
# when it's set — e.g. CONTAINER_NAME=myntopng renames ntopng to
# "myntopng" and the sidecar to "myntopng-ntopng-redis". Leave unset to
# keep the original bare names.
# Format: A single container name (no spaces).
CONTAINER_NAME=ntopng

# Network interfaces ntopng captures traffic on — deep per-flow analysis,
# DPI (nDPI), and historical trends (via its own Redis instance). Space-
# separated for multiple.
# Format: One or more interface names visible on the host (ip link show).
# Examples: eth0        (single)
#           eth0 wlan0  (both wired and wireless)
NTOPNG_INTERFACES=eth0

# Host port for the ntopng web UI.
# Format: A valid local TCP port. Access via http://<pi-ip>:<port>
# Default login is admin/admin — you'll be prompted to change it on first
# login; there's no env var to pre-seed a different password.
NTOPNG_PORT=3002
