# The unique alphanumeric identifier name assigned to this active SDR container instance.
CONTAINER_NAME=sdr-dragonos-core

# The specific Docker image tag compiled and referenced during the deployment phase.
DOCKER_IMAGE_TAG=dragonos-pi

# The graphical environment display target string used to bridge the host X11 server socket.
DISPLAY=:0

# The physical host filesystem directory mapping pointing to the system USB routing bus.
HOST_USB_BUS_PATH=/dev/bus/usb

# The directory boundary containing the active host system UNIX socket for X11 screen rendering.
HOST_X11_UNIX_PATH=/tmp/.X11-unix

# The physical hardware sound card device node passed from the host Linux kernel layer.
HOST_SOUND_DEVICE=/dev/snd

# The native execution runtime path where the host desktop user session daemons reside.
HOST_XDG_RUNTIME_DIR=/run/user/1000

# The path to the active PulseAudio or PipeWire communication socket for audio forwarding.
HOST_PULSE_NATIVE_SOCKET=/run/user/1000/pulse/native

# The location of the binary PulseAudio token cookie required to authorize client streams.
HOST_PULSE_COOKIE_PATH=~/.config/pulse/cookie

# The target host directory path where captured SDR IQ files and security logs are recorded.
HOST_CAPTURES_PATH=./workspace/captures

# The target host directory path where custom Metasploit, GNU Radio, or module files reside.
HOST_MSF_DATA_PATH=./workspace/msf_data

# The default internal execution directive triggered when accessing the container.
CONTAINER_ENTRYPOINT_COMMAND=/usr/local/bin/sdr-menu.sh