# NanoClaw is a host-level Node.js service — it manages Docker containers
# per conversation group internally. There is no single fixed container name.
# This .env configures the host-side install path and web UI port only.
# The Anthropic API key is registered interactively by nanoclaw.sh on first install.
CONTAINER_NAME=

# Absolute path where the nanoclaw repo will be cloned and installed.
# Format: An absolute path on the host where the pi user has write access.
NANOCLAW_INSTALL_PATH=/home/pi/nanoclaw

# The port exposed by the NanoClaw web interface for browser-based conversations.
# Format: A valid local TCP port number. Default is 3080.
NANOCLAW_PORT=3080
