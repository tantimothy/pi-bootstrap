# NanoClaw is a host-level Node.js service — it manages Docker containers
# per conversation group internally. This .env configures the install path,
# web UI port, and deploy mode. The Anthropic API key is registered
# interactively by nanoclaw.sh on first install.

# In "container" deploy mode this is the single orchestrator container's
# name (see NANOCLAW_DEPLOY_MODE below); the per-conversation-group agent
# containers it spawns are dynamic and not covered by this. In "host" mode
# there's no Docker container for the orchestrator itself, so this is only
# meaningful in container mode.
CONTAINER_NAME=nanoclaw

# Absolute path where the nanoclaw repo will be cloned and installed.
# Format: An absolute path where the current user has write access, or a
# leading ~ (expanded to your home directory when this is written to .env
# via deploy.sh's TUI — plain "~"/"~/..." only, not "~otheruser/...").
# In container mode this is bind-mounted into the orchestrator container
# at the SAME absolute path (not remapped to something else) — required
# so the orchestrator can correctly spawn per-conversation-group agent
# containers via the host's Docker socket. See the README's "Deployment
# Modes" section before changing how this is mounted.
NANOCLAW_INSTALL_PATH=~/nanoclaw

# NanoClaw has no web UI by default (its own README: "no monitoring
# dashboard or debugging UI — describe the problem in chat"). This just
# pre-reserves a port on the container in case you later add its optional
# /add-dashboard skill (a separate npm package with its own DASHBOARD_PORT/
# DASHBOARD_SECRET, not read from this variable at all).
# Format: A valid local TCP port number. Default is 3080.
NANOCLAW_PORT=3080

# How the NanoClaw orchestrator itself runs. "container" sandboxes it in
# Docker — no host filesystem access beyond NANOCLAW_INSTALL_PATH, but no
# iMessage support (that needs real macOS Messages.app/TCC access a Linux
# container can never reach, even on macOS, since Docker Desktop there
# runs containers inside a Linux VM). "host" runs it as a bare systemd
# (Linux) / launchd (macOS) service with full access to whatever the OS
# user account can read/write — supports iMessage on macOS. Leave blank
# to auto-select by OS: macOS defaults to "container", Linux defaults to
# "host". See the README's "Deployment Modes" section for the full
# tradeoff before overriding this.
# Format: "container", "host", or blank for the OS-based default.
NANOCLAW_DEPLOY_MODE=
