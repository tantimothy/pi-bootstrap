# The multi-container identification tracking array used by the TUI engine to audit and prune states.
# Format: Space-separated string array matching service container names exactly.
CONTAINER_NAME=pihole wg-easy pihole-exporter wireguard-exporter prometheus grafana uptime-kuma node-exporter speedtest-exporter blackbox-exporter

# The timezone utilized by the underlying architecture to synchronize metric logs and network handshakes.
# Format: A valid IANA TZ database string (e.g., UTC, America/New_York, Asia/Singapore).
TZ=Asia/Singapore

# The administrative web access token password used to secure the Pi-hole v6 management dashboard.
# Format: Plaintext string. Mandatory entry; must be initialized securely by the operator.
FTLCONF_webserver_api_password=CHANGE_ME_TO_A_SECURE_PASSWORD

# The host machine network interface port mapped directly to the internal Pi-hole web portal.
# Format: A valid local TCP socket port. Use port 80 (the default) for PADD compatibility.
PIHOLE_WEB_PORT=80

# The hardcoded internal IP address assigned to the Pi-hole container node inside the private bridge network.
# Format: A clean local IPv4 address. Default fallback matches the project pipeline configuration.
PIHOLE_INTERNAL_IP=172.20.0.2

# The public WAN static IP address or fully qualified DDNS domain used by remote VPN peers to establish handshakes.
# Format: An external internet-accessible endpoint (e.g., vpn.yourdomain.com). Mandatory entry.
WG_HOST=CHANGE_ME_TO_YOUR_PI_IP_OR_DDNS

# The physical interface port listening on the host machine for inbound encrypted WireGuard traffic.
# Format: A valid UDP port number matching your network edge router gateway forwarding rule.
WG_PORT=51820

# The host port assigned to navigate the wg-easy management control board.
# Format: A valid local TCP port. Accessible via browser string http://<your_pi_ip>:<this_port>.
WG_UI_PORT=51821

# The cryptographically hashed bcrypt token securing the wg-easy management dashboard portal.
# Format: A valid bcrypt hash generated via command: docker run --rm -it ghcr.io/wg-easy/wg-easy wgpw 'pass'
PASSWORD_HASH=CHANGE_ME_TO_YOUR_BCRYPT_HASH

# Specifies the target subnets that should have packets routed back through the encrypted VPN tunnel interface.
# Format: CIDR syntax. Set to 0.0.0.0/0 for full internet interception, or a local subnet for split-tunnel paths.
WG_ALLOWED_IPS=0.0.0.0/0

# The hardcoded internal IP address assigned to the wg-easy gateway inside the private bridge network.
# Format: A clean local IPv4 address inside the project's assigned network boundary.
WG_INTERNAL_IP=172.20.0.3

# The private virtual network bridge subnet generated by the Docker backend to facilitate internal pipelines.
# Format: CIDR syntax block. Must completely envelope the internal IP addresses declared above.
DOCKER_SUBNET=172.20.0.0/16

# Host port for the Grafana monitoring dashboard.
# Format: A valid local TCP port. Access via http://<pi-ip>:<port>
GRAFANA_PORT=3030

# Admin password for Grafana. Log in at the Grafana URL with username "admin".
# Format: Plaintext string. Set a strong password before first deploy.
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_TO_A_SECURE_PASSWORD

# Host port for the Uptime Kuma status and uptime monitoring dashboard.
# Format: A valid local TCP port. Access via http://<pi-ip>:<port>
UPTIME_KUMA_PORT=3001