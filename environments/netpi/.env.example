# ==============================================================================
# PIPIN INFRASTRUCTURE CONFIGURATION TEMPLATE (.env.example)
# This file is dynamically parsed by the TUI configuration utility to generate
# your active production environment variables.
# ==============================================================================

# The timezone used by the containers to log system metrics and schedule events.
# Format: A valid continent/city string from the IANA TZ database.
TZ=Asia/Singapore

# ==============================================================================
# PI-HOLE v6 CONFIGURATION
# ==============================================================================

# The administrative web portal access password for the Pi-hole v6 dashboard.
# Format: Plaintext string. Ensure this is strong and kept confidential.
FTLCONF_webserver_api_password=

# The local host port mapped to the Pi-hole container web server.
# Format: A standard TCP port number. Change this if port 8080 is already in use.
PIHOLE_WEB_PORT=8080

# The static internal container IP allocated to Pi-hole within the custom Docker network bridge.
# Format: A valid IPv4 address inside the project's assigned subnet.
PIHOLE_INTERNAL_IP=172.20.0.2

# ==============================================================================
# WIREGUARD (WG-EASY) CONFIGURATION
# ==============================================================================

# The public-facing endpoint address that remote VPN clients will connect to.
# Format: A public WAN static IP address or a fully qualified DDNS hostname (e.g., vpn.yourdomain.com).
WG_HOST=

# The host network listening port for incoming encrypted WireGuard tunnel packets.
# Format: A standard UDP port number (typically 51820). This must match your router's port-forwarding rule.
WG_PORT=51820

# The local host web management port for the wg-easy dashboard UI.
# Format: A standard TCP port number. Access via http://<your_pi_ip>:<this_port>.
WG_UI_PORT=51821

# The cryptographically hashed password used to secure the wg-easy web management portal.
# Format: A bcrypt hash string. Generate this on your host terminal before running the stack using:
# docker run --rm -it ghcr.io/wg-easy/wg-easy wgpw 'your_plaintext_password'
PASSWORD_HASH=

# Specifies the IP subnets that should be routed through the VPN tunnel.
# Format: Classless Inter-Domain Routing (CIDR) notation. 
# Use '0.0.0.0/0' to route ALL remote client device internet traffic through the Pi (Full Tunnel).
# Use your home network subnet (e.g., '192.168.1.0/24') to only route local traffic (Split Tunnel).
WG_ALLOWED_IPS=0.0.0.0/0

# The static internal container IP allocated to wg-easy within the custom Docker network bridge.
# Format: A valid IPv4 address inside the project's assigned subnet.
WG_INTERNAL_IP=172.20.0.3

# ==============================================================================
# NETWORKING DEFINITIONS
# ==============================================================================

# The isolated custom private subnet block managed by Docker Compose for container-to-container communication.
# Format: Classless Inter-Domain Routing (CIDR) notation.
DOCKER_SUBNET=172.20.0.0/16