# ==============================================================================
# DRAGONOS CORE SDR CONTAINER - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================

# The graphical environment display variable used to forward the X11 socket.
# Usually ':0' on local desktops or inherited via '$DISPLAY' on the host.
DISPLAY=:0

# The physical host directory mapping for the system USB bus infrastructure.
# Required by the container to talk directly to RTL-SDR or HackRF hardware.
HOST_USB_BUS_PATH=/dev/bus/usb

# The directory containing the local host system Unix socket for the X11 server.
# Used for rendering graphical SDR interfaces like GQRX or GNU Radio Companion.
HOST_X11_UNIX_PATH=/tmp/.X11-unix

# The physical sound card layer device directory mapped from the host system.
# Necessary for direct driver access to hardware audio cards.
HOST_SOUND_DEVICE=/dev/snd

# The native runtime runtime directory path for the host sound architecture.
# Typically points to '/run/user/1000' or similar system dynamic paths.
HOST_XDG_RUNTIME_DIR=/run/user/1000

# The path to the PulseAudio or PipeWire native communication UNIX socket.
# Allows the containerized SDR software to pipe decoded audio to your speakers.
HOST_PULSE_NATIVE_SOCKET=/run/user/1000/pulse/native

# The location of the PulseAudio cookie file on the host machine.
# Used to authenticate the containerized client with the host's audio daemon.
HOST_PULSE_COOKIE_PATH=~/.config/pulse/cookie

# The persistent directory path on the host used to store SDR work files.
# Binds to the workspace folder inside the container so your data isn't lost on exit.
HOST_WORKSPACE_VOLUME=./workspace

# The target execution command when launching the container.
# Set to the interactive TUI menu script, or change to '/bin/bash' for a raw shell.
CONTAINER_ENTRYPOINT_COMMAND=/usr/local/bin/sdr-menu.sh

# The unique identifier name assigned to this active Docker container instance.
CONTAINER_NAME=my-dragonos

# The specific Docker image tag built and utilized for this SDR deployment.
DOCKER_IMAGE_TAG=dragonos-pi