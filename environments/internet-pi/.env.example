# Absolute path where the internet-pi repo will be cloned on the Pi.
INTERNET_PI_INSTALL_PATH=/home/pi/internet-pi

# Timezone for Pi-hole and Grafana.
# Format: IANA TZ string (e.g. UTC, America/New_York, Asia/Singapore).
PIHOLE_TIMEZONE=Asia/Singapore

# Admin password for the Pi-hole web dashboard.
# Note: internet-pi's Pi-hole is separate from the pihole-wireguard environment.
# Run only one at a time — both bind port 53 and 80 on the host.
PIHOLE_PASSWORD=CHANGE_ME_TO_A_SECURE_PASSWORD

# Set to false to skip Pi-hole deployment entirely.
PIHOLE_ENABLE=true

# Set to false to skip the Prometheus + Grafana + speedtest/ping stack.
MONITORING_ENABLE=true

# Admin password for the Grafana dashboard (login: admin).
MONITORING_GRAFANA_ADMIN_PASSWORD=CHANGE_ME_TO_A_SECURE_PASSWORD

# How often to run an internet speed test (results appear in Grafana).
# Format: Ansible duration string — 60m, 30m, 1h.
MONITORING_SPEEDTEST_INTERVAL=60m
