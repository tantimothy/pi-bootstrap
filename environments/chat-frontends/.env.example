# AI Chat Frontends — a small hub of browser-based chat UIs, all pointed
# at the same host Ollama daemon (nanoclaw-mnemon's own Ollama setup, or
# any Ollama install already running on this machine) unless you tell one
# to talk to something else. Independent of NanoClaw entirely — deploy this
# whether or not you run any of the nanoclaw environments.

# Space-separated container names this environment manages — used by
# deploy.sh's CLEAN policy to identify which containers to tear down.
# Only the flagship (Open WebUI) service uses this literally; every other
# service below is prefixed with it instead (open-webui-sillytavern, etc.)
# — see docker-compose.yml's own comment on why.
# Format: A single Docker container name.
CONTAINER_NAME=open-webui

# Which frontends actually run — a comma-separated list of Docker Compose
# profile names, matching the "profiles:" list on each service in
# docker-compose.yml. This is a REAL Docker Compose mechanism (COMPOSE_PROFILES
# is read straight out of .env automatically, nothing this repo invented) —
# add or remove names to turn a service on or off, then redeploy (FAST is
# enough, no rebuild needed). "all" runs everything, including LobeHub's own
# Postgres database (see LOBEHUB_* below for why that one's excluded here
# by default — it's a much heavier addition than the other two).
# Format: Comma-separated, from: open-webui, sillytavern, lobehub (or "all").
COMPOSE_PROFILES=open-webui,sillytavern

# Host port for Open WebUI's own interface.
# Format: A valid local TCP port. Access via http://<host-ip>:<port>
OPEN_WEBUI_PORT=3010

# Where Open WebUI (and LobeHub, if enabled) looks for Ollama. Defaults to
# host.docker.internal, Docker's own hostname for reaching the host machine
# from inside a container — correct if you followed the nanoclaw-mnemon
# environment's own Ollama setup (host-native, not containerized — see that
# environment's README for why). Change this only if Ollama runs somewhere
# else (a different machine, a container of its own, a non-default port).
#
# Known caveat on OrbStack specifically (confirmed directly this session):
# host.docker.internal there resolves to OrbStack's own internal pseudo-
# address, not this bridge network's actual gateway — this breaks reaching
# another *container's* published port through it, but the HOST's own
# Ollama daemon (a real process, not a container) is still reachable fine,
# since that's exactly the case this mechanism is designed for. If it still
# doesn't work, find your bridge's real gateway IP and use that instead:
#   docker network inspect bridge --format '{{json .IPAM.Config}}'
# Format: A URL these containers can reach.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Whether Open WebUI requires sign-in. Leave this on unless you have a
# specific reason not to — Open WebUI's own first-run creates the initial
# admin account from whoever signs up first, so leaving auth off on a
# network-reachable instance lets anyone reach your Ollama models directly.
# Format: true or false.
WEBUI_AUTH=true

# Host port for SillyTavern's own interface (its own documented default —
# matches upstream's own docker-compose.yml exactly, unchanged here).
# Only relevant if "sillytavern" is in COMPOSE_PROFILES above.
# Format: A valid local TCP port. Access via http://<host-ip>:<port>
SILLYTAVERN_PORT=8000

# --- LobeHub (formerly LobeChat) — heavier than the two above, opt-in ---
# only via COMPOSE_PROFILES. Current upstream docs require a real Postgres
# database (no client-side/DB-less mode exists anymore) — these three
# values are all mandatory if you add "lobehub" to COMPOSE_PROFILES above.

# Host port for LobeHub's own interface. Only relevant if "lobehub" is in
# COMPOSE_PROFILES above.
# Format: A valid local TCP port. Access via http://<host-ip>:<port>
LOBEHUB_PORT=3210

# Password for LobeHub's own dedicated Postgres database (a separate
# container this environment manages, not your host's own Postgres if you
# happen to have one). Generate one yourself — don't leave the placeholder.
# Format: A password string, e.g. from `openssl rand -base64 24`.
LOBEHUB_DB_PASSWORD=CHANGE_ME_TO_A_SECURE_PASSWORD

# LobeHub's own required secrets — encrypts stored API keys
# (KEY_VAULTS_SECRET) and signs auth sessions (AUTH_SECRET). Generate real
# values for both; leaving these as placeholders is a real security gap if
# this instance is reachable by anyone but you.
# Format: A random string, e.g. from `openssl rand -base64 32` (run it
# twice — these two must NOT be the same value as each other).
LOBEHUB_KEY_VAULTS_SECRET=CHANGE_ME_RUN_OPENSSL_RAND_BASE64_32
LOBEHUB_AUTH_SECRET=CHANGE_ME_RUN_OPENSSL_RAND_BASE64_32_AGAIN
