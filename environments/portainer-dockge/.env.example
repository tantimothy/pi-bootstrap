# Space-separated container names this environment manages — used by
# deploy.sh's CLEAN policy to identify which containers to tear down.
# Format: Space-separated string matching service container names exactly.
CONTAINER_NAME=portainer dockge

# Host port for Portainer's web UI (plain HTTP, no certificate warning).
# Format: A valid local TCP port. Access via http://<pi-ip>:<port>
PORTAINER_PORT=9000

# Host port for Portainer's HTTPS web UI (self-signed certificate — your
# browser will warn on first visit). Optional; only needed if you want an
# encrypted connection to Portainer specifically. Access via
# https://<pi-ip>:<port>
PORTAINER_HTTPS_PORT=9443

# Host port for Dockge's web UI.
# Format: A valid local TCP port. Access via http://<pi-ip>:<port>
DOCKGE_PORT=5001
