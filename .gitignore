.DS_Store

# Marker files run.sh touches to record that an environment has been launched
environments/*/.deployed

# Config fingerprint used by dragonos-sdr/kali-pentest to detect drift
# between an existing container and the current run.sh settings
environments/*/.container-config-hash

# Generated by info.sh's "list" action — always freshly regenerated, never
# something to track in git
environments/*/post-deploy-info.html

# Full session recordings of every FAST/STOP/TEARDOWN/CLEAN/INFO/WIPE run —
# see _run_logged in lib/deploy-lib.sh. Local troubleshooting artifacts,
# not something to track in git (and .env values a run echoes back could
# end up in here).
environments/*/logs/
